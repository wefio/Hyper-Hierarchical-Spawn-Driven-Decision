# HHSDD 环境配置
# 复制为 .env 后填入实际值：cp .env.example .env

# ── API ──
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com
MODEL=claude-sonnet-4-20250514

# ── 能量系统 (1E = 1 token，总能量 = CONTEXT_BUDGET - CONTEXT_RESERVE) ──
CONTEXT_BUDGET=204800
CONTEXT_RESERVE=50000
STEP_OVERHEAD=1000
TOKEN_COST_INPUT=1.0
TOKEN_COST_OUTPUT=3.0
SPAWN_INVEST_MIN=2000
SPAWN_RESERVE_RATIO=0.15
REWARD_BASE=5000
TOOL_ENERGY_COST=200
CMD_REFUND_PER_SEC=500

# ── 上下文管理 ──
COMPRESSION_THRESHOLD=0.9
TOOL_RESULT_BUDGET=4000
MAX_MESSAGE_CHARS=120000

# ── 安全网 (正常由能量系统停止) ──
MAX_STEPS=100
MAX_TOOL_ROUNDS=100
MAX_SPAWN_DEPTH=0

# ── 插件 ──
# 逗号分隔的插件模块名，留空禁用所有插件
# 示例：PLUGINS=example_plugin
PLUGINS=

# ── 策略 ──
AUTO_PLAN=smart
ENABLE_SUBTASK_DEDUP=true
